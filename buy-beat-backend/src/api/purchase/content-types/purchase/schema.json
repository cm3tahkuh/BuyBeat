{
  "kind": "collectionType",
  "collectionName": "purchases",
  "info": {
    "singularName": "purchase",
    "pluralName": "purchases",
    "displayName": "Purchase"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "purchases"
    },
    "beat_file": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::beat-file.beat-file",
      "inversedBy": "purchases"
    },
    "amount": {
      "type": "decimal"
    },
    "purchase_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "completed",
        "cancelled",
        "refunded"
      ]
    },
    "payment_provider": {
      "type": "string"
    },
    "license_pdf": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files"
      ]
    }
  }
}
